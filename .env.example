# === App ===
NEXT_PUBLIC_APP_URL=https://specialcarers.com
# Canonical site origin for public share links (og:url, /c/<slug>, copy-link).
# Falls back to NEXT_PUBLIC_APP_URL, then https://specialcarers.com.
NEXT_PUBLIC_SITE_URL=https://specialcarers.com
NEXT_PUBLIC_APP_ENV=development        # development | preview | production
NEXT_PUBLIC_DEFAULT_LOCALE=en-GB
# Set to "true" to expose US region UI (default: false until US launch)
NEXT_PUBLIC_REGION_US_ENABLED=false

# === Supabase ===
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # SERVER ONLY — never expose to browser

# === Cron ===
# Shared secret for Vercel cron routes (/api/cron/*). Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>`; routes 401 on a mismatch. Generate a
# long random value and set it in the Vercel project env. If unset, cron routes
# allow any caller (dev only — always set in preview/production).
CRON_SECRET=

# === Stripe (later) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=             # test-mode signing secret (Stripe dashboard → test mode)
# STRIPE_WEBHOOK_SECRET_LIVE=        # live-mode signing secret (Stripe dashboard → live mode). Set both — handler tries live first, falls back to test.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Memberships (consumer subscriptions) ---
# Gates the public membership UI (the /m/memberships page + its profile nav
# entry). Default false for the soft launch — the page returns 404 and the nav
# link is hidden until set to "true". The checkout API + Stripe webhook are NOT
# gated by this flag, so they stay live for internal testing.
NEXT_PUBLIC_MEMBERSHIPS_ENABLED=false
# Persistent mobile sign-in + biometric app-lock. Gates the Face ID / Touch ID
# lock screen on the /m surface (cold-start + resume-after-5-min) and the
# "App lock" toggle in Profile › More. Default false — while off the /m app
# behaves exactly as today (no lock screen, toggle hidden). Client-readable
# because the gate runs entirely in the Capacitor WebView. Flip to "true" after
# TestFlight validation.
NEXT_PUBLIC_MOBILE_PERSISTENT_AUTH_ENABLED=false
# Designated Payer (gap 31). Billing-path feature: lets a family nominate a
# different adult in their household to be billed for a booking. Default false —
# while off, the designated-payer API routes 403 and the payment flow ignores
# bookings.designated_payer_user_id entirely (behaviour identical to legacy).
# Server-side flag (no NEXT_PUBLIC_ prefix); flip per-environment after rollout
# review.
FAMILY_DESIGNATED_PAYER_ENABLED=false
# Product IDs — used by the webhook to map a Stripe Product back to a plan code.
# STRIPE_PRODUCT_LITE=prod_...
# STRIPE_PRODUCT_PLUS=prod_...
# STRIPE_PRODUCT_PREMIUM=prod_...
# Price IDs — used by POST /api/memberships/checkout to open a subscription
# Checkout Session. Create recurring GBP Prices in Stripe and paste the ids here.
# The /m/memberships Subscribe CTA returns a clean error for any plan whose
# monthly price is unset, so tiers can ship incrementally.
# STRIPE_PRICE_LITE_MONTHLY=price_...
# STRIPE_PRICE_LITE_YEARLY=price_...
# STRIPE_PRICE_PLUS_MONTHLY=price_...
# STRIPE_PRICE_PLUS_YEARLY=price_...
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# STRIPE_PRICE_PREMIUM_YEARLY=price_...

# === Mapbox ===
# Public token (pk.*). Used server-side for geocoding (postcode -> lat/lng,
# powering the carer search "Nearest" sort) and client-side for map rendering.
# Mapbox no longer needs a secret token for geocoding. When unset (or prefixed
# "stub_"), src/lib/mapbox/server.ts runs in stub mode with deterministic fake
# coords so search/geocode work end-to-end before real credentials arrive.
# MAPBOX_PUBLIC_TOKEN=
# Secret token (sk.*) — only for admin APIs (uploads, tilesets). Not needed for
# geocoding or tracking.
# MAPBOX_SECRET_TOKEN=
# MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12

# === Twilio (later) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# === Email (later) ===
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=hello@specialcarers.com

# === Sentry (error + performance monitoring) ===
# Leave ALL of these unset locally and the SDK silently no-ops (no events sent,
# no build-time source-map upload). Populate them in Vercel for preview/prod.
# The DSN is safe to expose to the browser; the auth token is server-only and
# used solely for source-map upload during the build.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=                 # SERVER/CI ONLY — source-map upload token
# SENTRY_ORG=by-the-home-owner-group-ltd
# SENTRY_PROJECT=specialcarer-web

# === BACS18 Direct Credit export (Phase 4 — gated) ===
# Set FEATURE_BACS18_EXPORT_ENABLED=true once Lloyds has issued the SUN AND
# the four originator vars below are populated. Until then the route at
# /api/admin/payroll/runs/[id]/bacs-export returns 404 so it doesn't leak.
# FEATURE_BACS18_EXPORT_ENABLED=true
# BACS_ORIGINATOR_SUN=123456           # 6-digit Service User Number from Lloyds
# BACS_ORIGINATOR_SORT_CODE=207692     # 6 digits, no hyphens
# BACS_ORIGINATOR_ACCOUNT=12345678     # 8 digits, zero-padded
# BACS_ORIGINATOR_NAME=ALL CARE 4 U GROUP  # <=18 chars, BACS character set

# === Whereby Embedded — video interviews (gated) ===
# Set INTERVIEWS_VIDEO_ENABLED=true once the API key + webhook secret below are
# populated in Vercel and smoke-tested on staging. Until then the interview
# room routes return 403 and the Join UI stays hidden.
WHEREBY_API_KEY=
WHEREBY_API_BASE=https://api.whereby.dev/v1
WHEREBY_SUBDOMAIN=
WHEREBY_WEBHOOK_SECRET=
INTERVIEWS_VIDEO_ENABLED=false

# === Veriff — identity verification (gated) ===
# Set IDENTITY_VERIFICATION_ENABLED=true once VERIFF_API_KEY +
# VERIFF_SIGNATURE_KEY below are populated in Vercel, the Veriff webhook +
# callback URLs point at our endpoints, and a staging smoke test passes. Until
# then the identity routes return 403 and the VerifyIdentityCard stays hidden.
# X-AUTH-CLIENT uses VERIFF_API_KEY; X-HMAC-SIGNATURE uses VERIFF_SIGNATURE_KEY.
IDENTITY_VERIFICATION_ENABLED=false
VERIFF_BASE_URL=https://stationapi.veriff.com
VERIFF_API_KEY=
VERIFF_SIGNATURE_KEY=
# Optional: separate sandbox creds used in preview deploys only. Documented but
# NOT consumed by code in this PR — env-aware switching is a follow-up.
VERIFF_TEST_API_KEY=
VERIFF_TEST_SIGNATURE_KEY=

# === DBS verification (gated, PR-DBS-1) ===
# Every carer needs an Enhanced DBS for BOTH Adult AND Child workforce. With
# NEXT_PUBLIC_DBS_ENABLED off (default), the DBS UI is hidden, search/booking
# gating is a no-op, and the DBS service write paths throw DbsDisabledError.
# Flip to true once the schema migration is applied and a smoke test passes.
NEXT_PUBLIC_DBS_ENABLED=false
# Vendor selection: 'mock' (in-memory state machine, dev default) | 'ucheck'
# (real REST integration, PR-DBS-2). UCheck only releases its endpoint contract
# to partners under onboarding, so UCHECK_API_BASE lets us point at the sandbox
# host during onboarding and the prod host once approved. See the assumptions
# block at the top of src/lib/dbs/vendor.ts.
DBS_VENDOR=mock
UCHECK_API_KEY=
UCHECK_API_BASE=https://api.ucheck.co.uk/v1
# Recipient for DBS Update Service admin alerts (change-pending / invalidated).
# Falls back to ops@specialcarers.com when unset.
DBS_ADMIN_EMAIL=ops@specialcarers.com
