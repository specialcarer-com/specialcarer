# === App ===
NEXT_PUBLIC_APP_URL=https://specialcarer.com
NEXT_PUBLIC_APP_ENV=development        # development | preview | production
NEXT_PUBLIC_DEFAULT_LOCALE=en-GB

# === Supabase ===
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # SERVER ONLY — never expose to browser

# === Stripe (later) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=             # test-mode signing secret (Stripe dashboard → test mode)
# STRIPE_WEBHOOK_SECRET_LIVE=        # live-mode signing secret (Stripe dashboard → live mode). Set both — handler tries live first, falls back to test.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Mapbox (later) ===
# NEXT_PUBLIC_MAPBOX_TOKEN=

# === Twilio (later) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# === Email (later) ===
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=hello@specialcarer.com

# === Sentry (later) ===
# NEXT_PUBLIC_SENTRY_DSN=
